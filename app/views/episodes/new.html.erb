<div class=" w-1/3 bg-white rounded-lg shadow">
  <div class=" px-4 py-5 sm:p-6">
    
    <div class='flex flex-row justify-between items-center mb-6'>
        <h1 class="text-xl font-bold mb-4">New Episode</h1>
    </div>
    <%= form_with model: @episode, local: true do |f| %>
  <!-- Title -->
  <div class="mb-4">
    <%= f.label :title, class: "block font-semibold mb-1" %>
    <%= f.text_field :title, class: "w-full border rounded px-3 py-2" %>
  </div>

  <!-- Description -->
  <div class="mb-4">
    <%= f.label :description, class: "block font-semibold mb-1" %>
    <%= f.text_area :description, class: "w-full border rounded px-3 py-2" %>
  </div>

  <!-- Duration -->
  <div class="mb-4">
    <%= f.label :duration, "Duration (seconds)", class: "block font-semibold mb-1" %>
    <%= f.number_field :duration, class: "w-full border rounded px-3 py-2" %>
  </div>

  <!-- Audio URL -->
  <div class="mb-4">
    <%= f.label :audio_url, "Audio URL", class: "block font-semibold mb-1" %>
    <%= f.url_field :audio_url, class: "w-full border rounded px-3 py-2" %>
  </div>

  <div class="mb-4">
    <%= label_tag :tag_list, "Tags (comma-separated)", class: "block font-semibold mb-1" %>
    <%= text_field_tag :tag_list, '', class: "w-full border rounded px-3 py-2" %>
  </div>

  <%= f.submit "Create Episode", class: "bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded shadow" %>
<% end %>

</div>
  <div class="bg-gray-50 px-4 py-4 sm:px-6">
    <%= link_to "← Back to episodes", root_path, class: "text-indigo-600 hover:text-indigo-900" %>
  </div>
  </div>    